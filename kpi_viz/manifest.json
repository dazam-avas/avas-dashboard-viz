{
  "name": "AvasFlowers Funnel Bar Comparison",
  "description": "Funnel bar chart with fully custom current vs comparison date ranges, computed live in-browser.",
  "version": "1",
  "components": [
    {
      "id": "barComparison",
      "name": "Funnel Bar Comparison",
      "iconUrl": "https://www.gstatic.com/images/icons/material/system/2x/bar_chart_black_24dp.png",
      "type": "VISUALIZATION",
      "resource": {
        "js": "main.js",
        "css": "main.css"
      },
      "data": [
        {
          "id": "stepDim",
          "label": "Funnel step",
          "elements": [
            { "id": "stepDim", "type": "DIMENSION", "options": ["TEXT"], "min": 1, "max": 1 }
          ]
        },
        {
          "id": "dateDim",
          "label": "Date",
          "elements": [
            { "id": "dateDim", "type": "DIMENSION", "options": ["DATE"], "min": 1, "max": 1 }
          ]
        },
        {
          "id": "valueMetric",
          "label": "Step count",
          "elements": [
            { "id": "valueMetric", "type": "METRIC", "options": ["NUMBER"], "min": 1, "max": 1 }
          ]
        }
      ],
      "style": [
        {
          "id": "colors",
          "label": "Colors",
          "elements": [
            { "id": "curColor", "type": "FONT_COLOR", "label": "Current period color", "defaultValue": "#C9A84C" },
            { "id": "cmpColor", "type": "FONT_COLOR", "label": "Comparison period color", "defaultValue": "#E8D89A" }
          ]
        }
      ]
    }
  ]
}
