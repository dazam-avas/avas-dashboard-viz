{
  "name": "AvasFlowers KPI Comparison",
  "description": "KPI card with fully custom current vs comparison date ranges, computed live in-browser.",
  "version": "1",
  "components": [
    {
      "id": "kpiComparison",
      "name": "KPI Comparison",
      "iconUrl": "https://www.gstatic.com/images/icons/material/system/2x/insert_chart_black_24dp.png",
      "type": "VISUALIZATION",
      "resource": {
        "js": "main.js",
        "css": "main.css"
      },
      "data": [
        {
          "id": "dateDim",
          "label": "Date",
          "elements": [
            {
              "id": "dateDim",
              "type": "DIMENSION",
              "options": ["DATE"],
              "min": 1,
              "max": 1
            }
          ]
        },
        {
          "id": "valueMetric",
          "label": "Value",
          "elements": [
            {
              "id": "valueMetric",
              "type": "METRIC",
              "options": ["NUMBER"],
              "min": 1,
              "max": 1
            }
          ]
        }
      ],
      "style": [
        {
          "id": "kpiLabel",
          "label": "KPI label",
          "elements": [
            {
              "id": "labelText",
              "type": "TEXTINPUT",
              "label": "Label shown above the numbers",
              "defaultValue": "Metric"
            }
          ]
        },
        {
          "id": "colors",
          "label": "Colors",
          "elements": [
            {
              "id": "accentColor",
              "type": "FONT_COLOR",
              "label": "Accent color",
              "defaultValue": "#C9A84C"
            }
          ]
        }
      ],
      "interactions": [
        { "id": "onDateRangeChange", "supportedActions": ["FILTER"] }
      ]
    }
  ]
}
